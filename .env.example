# API Keys for Site Sağlık Analiz
# Bu dosyayı .env olarak kaydedin ve değerleri doldurun.

# Anthropic Claude API (Analiz için Gerekli)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google PageSpeed Insights API (Gerçek performans verileri için opsiyonel)
PAGESPEED_API_KEY=your_google_pagespeed_key_here

# Supabase (Raporları kaydetmek için opsiyonel)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Resend (E-posta gönderimi için opsiyonel)
RESEND_API_KEY=your_resend_key
EMAIL_FROM=noreply@yourdomain.com
